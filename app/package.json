{
  "name": "whitebox-studio",
  "version": "0.22.0",
  "description": "小白盒：面向零基础创作者的离线白膜建模、镜头与动画导出工具",
  "main": "./out/main/index.js",
  "author": "Xiaobaihe Contributors",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "npm@11.12.1",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "validate:model-io": "vitest run src/renderer/src/import-export/model-io.test.ts",
    "validate:model-real": "node scripts/validate-khronos-meshopt.mjs",
    "validate:draco-packaged": "npm run build && electron-builder --dir --config.directories.output=test-results/draco-package && node scripts/validate-khronos-draco-packaged.mjs",
    "validate:ktx2-packaged": "npm run build && electron-builder --dir --config.directories.output=test-results/ktx2-package && node scripts/validate-khronos-ktx2-packaged.mjs",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "legal:generate": "node scripts/generate-legal-notices.mjs",
    "legal:verify": "node scripts/generate-legal-notices.mjs --check",
    "verify": "npm run legal:verify && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run legal:generate && npm run build && node scripts/build-release.mjs --dir",
    "build:win": "npm run legal:generate && npm run build && node scripts/build-release.mjs --win",
    "release:checksums": "node scripts/create-release-checksums.mjs",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "lucide-react": "1.24.0",
    "mediabunny": "1.50.8"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "1.61.1",
    "@types/node": "22.19.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "5.1.1",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "9.39.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  }
}
